{
  "name": "rag-solution-clip-ollama-custom-retrieval",
  "version": "0.1.14",
  "attributes": {
    "Category": "Solution",
    "Solution Type": "GenAI",
    "Provider": "Dataloop",
    "Media Type": [
      "Text"
    ]
  },
  "displayName": "Custom CLIP & Ollama RAG - Retrieval",
  "description": "Retrieval pipeline for the Custom CLIP & Ollama RAG solution. Uses CLIP for query embedding and Dataloop's Hosted LLM via an Ollama server. Pipeline dependency services are scaled to 1 replica by default.",
  "scope": "public",
  "codebase": {
    "type": "git",
    "gitUrl": "https://github.com/dataloop-ai-apps/solution-applications.git",
    "gitTag": "0.1.14"
  },
  "dependencies": [
    {
      "name": "rag-template",
      "components": {
        "services": [
          {
            "runtime": {
              "autoscaler": {
                "type": "rabbitmq",
                "minReplicas": 1,
                "maxReplicas": 1,
                "queueLength": 1000
              }
            }
          }
        ]
      }
    },
    {
      "name": "dataset-chunks-rag-custom"
    },
    {
      "name": "clip-model-pretrained",
      "components": {
        "services": [
          {
            "runtime": {
              "autoscaler": {
                "type": "rabbitmq",
                "minReplicas": 1,
                "maxReplicas": 1,
                "queueLength": 1000
              }
            }
          }
        ]
      }
    },
    {
      "name": "ollama-server",
      "components": {
        "services": [
          {
            "runtime": {
              "autoscaler": {
                "type": "rabbitmq",
                "minReplicas": 1,
                "maxReplicas": 1,
                "queueLength": 1000
              }
            }
          }
        ]
      }
    },
    {
      "name": "hosted-chat-completion",
      "components": {
        "services": [
          {
            "runtime": {
              "autoscaler": {
                "type": "rabbitmq",
                "minReplicas": 1,
                "maxReplicas": 1,
                "queueLength": 1000
              }
            }
          }
        ],
        "models": [
          {
            "name": "hosted-chat-completion",
            "configuration": {
              "system_prompt": "You are a RAG based assistant. Answer by the context given and give the documents names in your response.",
              "model_name": "phi4-mini:latest",
              "add_metadata": [
                "system.originalname.filename"
              ],
              "app_id": "<APP_ID_TO_BE_SET>",
              "stream": true,
              "max_tokens": 4096,
              "temperature": 1.0,
              "top_p": 1.0
            }
          }
        ]
      }
    }
  ],
  "variables": {
    "sourceDataset__dataset": "dataset-chunks-rag-custom.datasets.Chunks Dataset",
    "embedderRetriever__model": "clip-model-pretrained.models.openai-clip",
    "embedder__model": "clip-model-pretrained.models.openai-clip",
    "genModel__model": "hosted-chat-completion.models.hosted-chat-completion"
  }
}
