{
  "name": "rag-solution-openai-transactions-preprocess",
  "version": "0.1.10",
  "attributes": {
    "Category": "Solution",
    "Solution Type": "GenAI",
    "Provider": "Dataloop",
    "Media Type": [
      "Text"
    ]
  },
  "displayName": "OpenAI RAG template - Transactions - Preprocess",
  "description": "This solution implements the RAG template, utilizing OpenAI's text embedder for query embedding, retrieving relevant documents, and using ChatGPT to generate context-aware responses. It preloads a recipes dataset as the source for document retrieval.",
  "scope": "public",
  "codebase": {
    "type": "git",
    "gitUrl": "https://github.com/dataloop-ai-apps/solution-applications.git",
    "gitTag": "0.1.10"
  },
  "dependencies": [
    {
      "name": "rag-preprocessing-template"
    },
    {
      "name": "dataset-openai-pdf-transactions"
    },
    {
      "name": "dataset-openai-text-transactions"
    },
    {
      "name": "text-embeddings-3"
    }
  ],
  "variables": {
    "sourceDataset__dataset": "dataset-openai-pdf-transactions.datasets.OpenAI Transactions PDF Dataset",
    "chunksDataset__dataset": "dataset-openai-text-transactions.datasets.OpenAI Transactions Text Dataset",
    "embedder__model": "text-embeddings-3.models.openai-prompt-embeddings-3l"
  }
}
