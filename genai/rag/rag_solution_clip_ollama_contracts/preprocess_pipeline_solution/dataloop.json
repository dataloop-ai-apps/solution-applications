    "gitTag": "0.1.14"
  },
  "dependencies": [
    {
      "name": "rag-preprocessing-template"
    },
    {
      "name": "dataset-caud-contracts"
    },
    {
      "name": "dataset-caud-contracts-chunks"
    },
    {
      "name": "clip-model-pretrained"
    }
  ],
  "variables": {
    "sourceDataset__dataset": "dataset-caud-contracts.datasets.CAUD Contracts PDF Dataset",
    "chunksDataset__dataset": "dataset-caud-contracts-chunks.datasets.CAUD Contracts Chunks Dataset",
    "embedder__model": "clip-model-pretrained.models.openai-clip"
