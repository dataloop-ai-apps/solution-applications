{
  "name": "vss-solution-nim-preprocess",
  "version": "0.1.13",
  "attributes": {
    "Category": "Solution",
    "Solution Type": "GenAI",
    "Provider": "Dataloop",
    "Media Type": [
      "Video"
    ]
  },
  "displayName": "NIM VSS Blueprint - Preprocess",
  "description": "This solution implements the Video Search & Summarization preprocessing pipeline powered by NVIDIA NIM. It ingests videos, splits them into chunks, generates visual descriptions (VILA VLM) and audio transcripts (Parakeet ASR), embeds the text, and builds a knowledge graph for downstream search and Q&A.",
  "scope": "public",
  "codebase": {
    "type": "git",
    "gitUrl": "https://github.com/dataloop-ai-apps/solution-applications.git",
    "gitTag": "0.1.10"
  },
  "dependencies": [
    {
      "name": "video-search-summarization-bp"
    },
    {
      "name": "dataset-nim-vss-text-chunks"
    },
    {
      "name": "dataset-nim-vss-source-videos"
    },
    {
      "name": "vila-model-adapter",
      "components": {
        "models": [
          {
            "name": "vila-1p5-3b",
            "configuration": {
              "model_path": "Efficient-Large-Model/VILA1.5-3b",
              "conv_mode": "vicuna_v1",
              "max_tokens": 1024,
              "temperature": 0.2,
              "top_p": 0.9,
              "stream": false
            }
          }
        ]
      }
    },
    {
      "name": "nim-llama-3-2-nemoretriever-1b-vlm-embed-v1",
      "components": {
        "models": [
          {
            "name": "nim-llama-3-2-nemoretriever-1b-vlm-embed-v1",
            "configuration": {
              "nim_model_name": "nvidia/llama-3.2-nemoretriever-1b-vlm-embed-v1",
              "embeddings_size": 2048
            }
          }
        ]
      }
    },
    {
      "name": "nim-llama-3-1-8b-instruct",
      "components": {
        "models": [
          {
            "name": "nim-llama-3-1-8b-instruct",
            "configuration": {
              "nim_model_name": "meta/llama-3.1-8b-instruct",
              "max_tokens": 4096,
              "temperature": 0.2,
              "top_p": 0.7,
              "stream": true,
              "base_url": "https://integrate.api.nvidia.com/v1",
              "system_prompt": "You are a knowledge-graph extraction engine. Given a text passage, extract the most important entities and the relationships between them.\n\nEntity rules:\n- Use Title Case canonical names (\"Assembly Line\", not \"assembly-line\").\n- Merge synonyms into one canonical name (pick the most common form, e.g. \"Car\" not \"car/vehicle/automobile\").\n- SKIP low-value entities: URLs, watermarks, colors, directions, generic sizes, timestamps.\n- Focus on meaningful nouns: people, objects, places, organizations, concepts, events.\n- Prefer specific names over generic ones (\"Forklift\" not \"Vehicle\", \"Warehouse\" not \"Building\").\n\nRelationship rules:\n- \"source\" and \"target\" MUST exactly match an entity \"name\".\n- \"relation\" must be a short UPPER_SNAKE_CASE verb (e.g. LOCATED_IN, OPERATES, CONTAINS, PART_OF, CAUSES, PRODUCES).\n- Only include relationships clearly stated or strongly implied.\n- Do NOT invent relationships that require speculation.\n\nReturn valid JSON matching the provided schema.",
              "guided_json": {
                "type": "object",
                "properties": {
                  "entities": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "name": { "type": "string", "description": "Canonical name of the entity" },
                        "type": { "type": "string", "description": "Entity type, e.g. Person, Object, Location, Organisation, Concept, Event, Equipment, Attribute" }
                      },
                      "required": ["name", "type"]
                    },
                    "minItems": 2,
                    "maxItems": 8
                  },
                  "relationships": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "source": { "type": "string", "description": "Must match an entity name exactly" },
                        "target": { "type": "string", "description": "Must match an entity name exactly" },
                        "relation": { "type": "string", "description": "UPPER_SNAKE_CASE verb, e.g. PLACES, CAUSES, LOCATED_IN" },
                        "description": { "type": "string", "description": "Free-text description of this relationship" }
                      },
                      "required": ["source", "target", "relation"]
                    },
                    "minItems": 1,
                    "maxItems": 10
                  }
                },
                "required": ["entities", "relationships"]
              },
              "add_metadata": [
                "system.document.source"
              ]
            }
          }
        ]
      }
    }
  ],
  "variables": {
    "sourceDataset__dataset": "dataset-nim-vss-source-videos.datasets.NIM VSS Source Videos Dataset",
    "chunksDataset__dataset": "dataset-nim-vss-text-chunks.datasets.NIM VSS Text Chunks Dataset",
    "vlm_model__model": "vila-model-adapter.models.vila-1p5-3b",
    "embedding_model__model": "nim-llama-3-2-nemoretriever-1b-vlm-embed-v1.models.nim-llama-3-2-nemoretriever-1b-vlm-embed-v1",
    "graph_llm_model__model": "nim-llama-3-1-8b-instruct.models.nim-llama-3-1-8b-instruct"
  }
}
